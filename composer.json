{
    "name": "apntalk/ami-client",
    "description": "High-performance, non-blocking Asterisk Manager Interface (AMI) client for PHP 8.4+",
    "type": "library",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "Apn\\AmiClient\\": "src/"
        }
    },
    "require": {
        "php": ">=8.4",
        "psr/log": "^3.0"
    },
    "suggest": {
        "illuminate/support": "Required to use the Laravel adapter in src/Laravel",
        "illuminate/console": "Required to use the Laravel adapter command integration"
    },
    "require-dev": {
        "illuminate/console": "^12.0",
        "illuminate/support": "^12.0",
        "phpoption/phpoption": "^1.9",
        "phpunit/phpunit": "^12.0",
        "vlucas/phpdotenv": "^5.6"
    },
    "config": {
        "sort-packages": true
    },
    "scripts": {
        "check:core-boundaries": "php scripts/validate_guidelines.php",
        "test:full-with-env-detection": "bash scripts/run_full_suite_with_env_detection.sh",
        "realpbx:test": "php scripts/realpbx_test.php"
    },
    "minimum-stability": "stable"
}
