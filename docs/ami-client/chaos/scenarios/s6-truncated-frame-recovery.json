{
  "id": "S6",
  "name": "truncated-frame-recovery",
  "server_count": 1,
  "client_settings": {
    "max_frames_per_tick": 1000,
    "max_events_per_tick": 1000,
    "max_bytes_read_per_tick": 65536,
    "max_connect_attempts_per_tick": 2,
    "event_queue_cap": 10000,
    "parser_buffer_cap": 65540,
    "max_frame_size": 65536,
    "write_buffer_cap": 5242880,
    "timeout_ms": 3000
  },
  "servers": [
    {
      "key": "node-a",
      "script": [
        {"type": "send_truncated_frame", "at_ms": 0, "frame": "Response: Success\r\nActionID: half-only"},
        {"type": "send_frame", "at_ms": 100, "frame": "Response: Success\r\nActionID: recovery\r\nMessage: intact", "delimiter": "\\r\\n\\r\\n"}
      ]
    }
  ],
  "expectations": ["buffer_cap_protected", "resync_success"]
}
