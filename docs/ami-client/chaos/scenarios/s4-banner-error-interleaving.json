{
  "id": "S4",
  "name": "banner-error-interleaving",
  "server_count": 1,
  "client_settings": {
    "max_frames_per_tick": 1000,
    "max_events_per_tick": 1000,
    "max_bytes_read_per_tick": 65536,
    "max_connect_attempts_per_tick": 2,
    "event_queue_cap": 10000,
    "parser_buffer_cap": 2097152,
    "max_frame_size": 1048576,
    "write_buffer_cap": 5242880,
    "timeout_ms": 3000
  },
  "servers": [
    {
      "key": "node-a",
      "script": [
        {"type": "send_banner", "at_ms": 0, "version": "Asterisk Call Manager/11.0.0"},
        {"type": "send_frame", "at_ms": 10, "frame": "Response: Error\r\nActionID: fixture-banner-001\r\nMessage: Permission denied", "delimiter": "\\r\\n\\r\\n"}
      ]
    }
  ],
  "expectations": ["banner_processed", "error_parsed_after_banner", "no_stall"]
}
