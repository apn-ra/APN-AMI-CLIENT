{
  "id": "S12",
  "name": "multi-server-fairness",
  "runner_mode": "multi_server",
  "server_count": 3,
  "client_settings": {
    "max_frames_per_tick": 20000,
    "max_events_per_tick": 1000,
    "max_bytes_read_per_tick": 65536,
    "max_connect_attempts_per_tick": 1,
    "event_queue_cap": 10000,
    "parser_buffer_cap": 2097152,
    "max_frame_size": 1048576,
    "write_buffer_cap": 5242880,
    "timeout_ms": 4000
  },
  "servers": [
    {"key": "node-a", "script": [{"type": "send_frame", "at_ms": 0, "frame": "Event: FloodEvent", "delimiter": "\\r\\n\\r\\n"}]},
    {"key": "node-b", "script": [{"type": "send_on_action", "action": "Ping", "delay_ms": 150, "frame": "Response: Success\\r\\nActionID: b:1", "delimiter": "\\r\\n\\r\\n"}]},
    {"key": "node-c", "script": [{"type": "send_on_action", "action": "Ping", "frame": "Response: Success\\r\\nActionID: c:1", "delimiter": "\\r\\n\\r\\n"}]}
  ],
  "expectations": ["no_starvation", "b_and_c_complete_within_timeout", "per_server_isolation"]
}
